# Whisper Service — Environment Variables
# Copy to .env and adjust as needed

# Model size: tiny | base | small | medium | large-v2 | large-v3
# Recommended for RTX 4060 (8GB): large-v3
WHISPER_MODEL=large-v3

# Inference device: cuda | cpu
# Use 'cpu' if no GPU is available (slower but still works)
WHISPER_DEVICE=cuda

# Compute precision: float16 (GPU) | int8 (CPU or low-VRAM)
WHISPER_COMPUTE_TYPE=float16
