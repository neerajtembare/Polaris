# Whisper Service — Environment Variables
# Copy to .env and adjust as needed.
#
# CPU mode (local dev, no GPU required):
#   WHISPER_MODEL=base
#   WHISPER_DEVICE=cpu
#   WHISPER_COMPUTE_TYPE=int8
#
# GPU mode (via docker-compose.ai.yml or local with CUDA):
#   WHISPER_MODEL=large-v3
#   WHISPER_DEVICE=cuda
#   WHISPER_COMPUTE_TYPE=float16

# Model size: tiny | base | small | medium | large-v2 | large-v3
# 'base' is fast on CPU and good enough for most use cases (~75MB)
# 'large-v3' gives the best accuracy but requires a GPU (~3GB VRAM)
WHISPER_MODEL=base

# Inference device: cuda | cpu
WHISPER_DEVICE=cpu

# Compute precision: float16 (GPU only) | int8 (CPU or low-VRAM GPU)
WHISPER_COMPUTE_TYPE=int8

